# Database
POSTGRES_DB=teamwiki
POSTGRES_USER=wiki
POSTGRES_PASSWORD=changeme123

# Redis
REDIS_URL=redis://redis:6379/0

# LLM primary (DashScope OpenAI-compatible)
LLM_API_KEY=your-dashscope-api-key
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen3.6-plus
LLM_PROVIDER=dashscope

# LLM fallback (Volcengine Ark — auto-triggers on primary 5xx/timeout/429)
# Leave FALLBACK_API_KEY empty to disable fallback.
FALLBACK_API_KEY=
FALLBACK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
FALLBACK_MODEL=doubao-seed-2-0-lite-260215
FALLBACK_PROVIDER=doubao

# Embedding (same DashScope API key)
EMBEDDING_MODEL=text-embedding-v3
EMBEDDING_DIM=1024

# MinerU (PDF parsing API)
MINERU_API_KEY=your-mineru-api-key-here

# Auth (leave empty to disable authentication)
AUTH_PASSWORD=your-team-password
SECRET_KEY=

# App
DATABASE_URL=postgresql+asyncpg://wiki:changeme123@postgres:5432/teamwiki
DATABASE_URL_SYNC=postgresql://wiki:changeme123@postgres:5432/teamwiki
RAW_STORAGE_PATH=/app/data/raw
